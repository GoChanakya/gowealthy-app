{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",

    "ios": {
      "bundleIdentifier": "com.gochanakya.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "android": {
      "package": "com.gochanakya.mobile"
    },

    "extra": {
      "eas": {
        "projectId": "af0b9f33-ca49-46c1-a377-9fe2cb83e14a"
      }
    },

    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useHermes": false,
            "newArchEnabled": false
          },
          "android": {
            "useHermes": false,
            "newArchEnabled": false
          }
        }
      ],
      "expo-font"
    ],

    "experiments": {
      "reactCompiler": false
    }
  }
}